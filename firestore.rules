rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Draft rules for Analite Kit.
    // NOTE: These rules assume Firebase Auth tokens with email/admin claims.
    // If you rely only on NextAuth sessions in the browser, add Firebase Auth sign-in
    // (or custom tokens) before enforcing strict owner/admin constraints in production.

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwner(userEmail) {
      return isSignedIn() && request.auth.token.email == userEmail;
    }

    match /catalog/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userEmail}/state/{docId} {
      allow read, write: if isOwner(userEmail) || isAdmin();
    }

    match /users/{userEmail}/profile/{docId} {
      allow read, write: if isOwner(userEmail) || isAdmin();
    }

    match /supportReports/{reportId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }
  }
}
